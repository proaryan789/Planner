        )}

        {/* ══ HISTORY TAB ══ */}
        {tab === "history" && (
          <HistoryTab dayTypes={dayTypes} tasks={tasks} />
        )}

        {/* ══ HABITS TAB ══ */}
        {tab === "habits" && (
          <HabitsTab selKey={selKey} habits={habits} setHabits={setHabits} selDate={selDate} />
        )}

      </div>
    </div>
  );
}

// ─── History Tab ──────────────────────────────────────────────────
function HistoryTab({ dayTypes, tasks }) {
  const keys = Object.keys(dayTypes).sort().reverse();

  const getDayPct = (dk) => {
    const tt = dayTypes[dk]==="normal"?NORMAL_TIMETABLE:HOLIDAY_TIMETABLE;
    const totalSlots = tt.reduce((a,s)=>a+calcSlots(s.time),0);
    const filled = tt.flatMap(s=>Array.from({length:calcSlots(s.time)},(_,i)=>tasks[`${dk}-${s.id}-${i}`])).filter(Boolean);
    if(!filled.length) return 0;
    return Math.round(filled.reduce((a,t)=>a+(t.pct||0),0)/totalSlots);
  };

  // streak calc
  let streak = 0;
  const td = new Date(); td.setHours(0,0,0,0);
  for (let i=0;i<365;i++) {
    const d = new Date(td); d.setDate(d.getDate()-i);
    const k = dateKey(d);
    if (dayTypes[k] && getDayPct(k)>0) streak++;
    else if (i>0) break;
  }

  // weekly avg
  const weekKeys = [];
  for(let i=0;i<7;i++){const d=new Date(td);d.setDate(d.getDate()-i);weekKeys.push(dateKey(d));}
  const weekDays = weekKeys.filter(k=>dayTypes[k]);
  const weekAvg  = weekDays.length ? Math.round(weekDays.reduce((a,k)=>a+getDayPct(k),0)/weekDays.length) : 0;

  return (
    <div style={{ padding:"16px 18px" }}>
      <h2 style={{ margin:"0 0 14px", fontSize:16, color:"#333", fontWeight:800 }}>📈 Progress History</h2>

      {/* Summary cards */}
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:10, marginBottom:16 }}>
        {[
          { label:"Days Tracked", val:keys.length, icon:"📅", color:"#FF6B00" },
          { label:"Day Streak",   val:`${streak}🔥`, icon:"", color:"#FF3B3B" },
          { label:"7-Day Avg",    val:`${weekAvg}%`, icon:"", color:"#4CAF50" },
        ].map(c=>(
          <div key={c.label} style={{ background:"#fff", border:"1.5px solid #FFE0C0", borderRadius:14, padding:"12px 8px", textAlign:"center", boxShadow:"0 2px 8px rgba(255,107,0,.05)" }}>
            <div style={{ fontSize:20, fontWeight:900, color:c.color }}>{c.val}</div>
            <div style={{ fontSize:10, color:"#aaa", marginTop:2, fontWeight:600 }}>{c.label}</div>
          </div>
        ))}
      </div>

      {keys.length === 0 ? (
        <div style={{ textAlign:"center", padding:48, color:"#ccc" }}>
          <div style={{ fontSize:40 }}>📊</div>
          <p style={{ fontSize:13, marginTop:8 }}>No history yet. Start planning!</p>
        </div>
      ) : (
        keys.map(dk => {
          const pct  = getDayPct(dk);
          const d    = new Date(dk+"T00:00:00");
          const tt   = dayTypes[dk]==="normal"?NORMAL_TIMETABLE:HOLIDAY_TIMETABLE;
          const filledTasks = tt.flatMap(s=>Array.from({length:calcSlots(s.time)},(_,i)=>tasks[`${dk}-${s.id}-${i}`])).filter(Boolean);
          return (
            <div key={dk} style={{ background:"#fff", border:"1.5px solid #FFE0C0", borderRadius:16, padding:"13px 14px", marginBottom:11, boxShadow:"0 2px 8px rgba(255,107,0,.05)" }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:9 }}>
                <div>
                  <div style={{ fontWeight:800, fontSize:14, color:"#333" }}>{WEEK_DAYS[d.getDay()]}, {d.getDate()} {MONTHS[d.getMonth()]} {d.getFullYear()}</div>
                  <div style={{ fontSize:11, color:"#aaa", marginTop:1 }}>
                    <span style={{ background:dayTypes[dk]==="normal"?"#FFF0E6":"#F0FFF4", color:dayTypes[dk]==="normal"?"#FF6B00":"#4CAF50", padding:"2px 8px", borderRadius:20, fontWeight:700, marginRight:6 }}>
                      {dayTypes[dk]==="normal"?"📚 Normal":"🎉 Holiday"}
                    </span>
                    {filledTasks.length} tasks logged
                  </div>
                </div>
                <div style={{ textAlign:"center" }}>
                  <div style={{ fontSize:24, fontWeight:900, color:pct===100?"#4CAF50":pct>=75?"#FF6B00":"#FFB347" }}>{pct}%</div>
                  <div style={{ fontSize:10, color:"#aaa" }}>done</div>
                </div>
              </div>
              <div style={{ background:"#FFE8D6", borderRadius:100, height:8 }}>
                <div style={{ width:`${pct}%`, height:"100%", borderRadius:100, background:pct===100?"#4CAF50":"linear-gradient(90deg,#FF6B00,#FFB347)", transition:"width .4s" }}/>
              </div>
              {/* Task list */}
              {filledTasks.length > 0 && (
                <div style={{ marginTop:10, display:"flex", flexDirection:"column", gap:5 }}>
                  {filledTasks.map((t,i)=>(
                    <div key={i} style={{ display:"flex", justifyContent:"space-between", alignItems:"center", padding:"5px 10px", background:"#FFFAF5", borderRadius:8, border:"1px solid #FFE0C0" }}>
                      <span style={{ fontSize:12, color:"#444", flex:1, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{t.text}</span>
                      <span style={{ fontSize:12, fontWeight:800, color:t.pct===100?"#4CAF50":"#FF6B00", marginLeft:8, flexShrink:0 }}>{t.pct||0}%</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          );
        })
      )}
    </div>
  );
}

// ─── Habits Tab ───────────────────────────────────────────────────
function HabitsTab({ selKey, habits, setHabits, selDate }) {
  const toggle = id => setHabits(p => ({ ...p, [`${selKey}-${id}`]: !p[`${selKey}-${id}`] }));
  const done = HABITS.filter(h => habits[`${selKey}-${h.id}`]).length;

  return (
    <div style={{ padding:"16px 18px" }}>
      <h2 style={{ margin:"0 0 2px", fontSize:16, color:"#333", fontWeight:800 }}>🔥 Daily Habits</h2>
      <p style={{ margin:"0 0 14px", fontSize:12, color:"#aaa" }}>
        {WEEK_DAYS[selDate.getDay()]}, {selDate.getDate()} {MONTHS_FULL[selDate.getMonth()]}
      </p>

      {/* Progress ring-style card */}
      <div style={{ background:"#FF6B00", borderRadius:18, padding:"16px", color:"#fff", marginBottom:16 }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:8 }}>
          <span style={{ fontWeight:800, fontSize:14 }}>Today's Habits</span>
          <span style={{ fontWeight:900, fontSize:22 }}>{done}/{HABITS.length}</span>
        </div>
        <div style={{ background:"rgba(255,255,255,.3)", borderRadius:100, height:12, overflow:"hidden" }}>
          <div style={{ height:"100%", borderRadius:100, background:"#fff", width:`${(done/HABITS.length)*100}%`, transition:"width .4s" }}/>
        </div>
        <p style={{ margin:"7px 0 0", fontSize:11, opacity:.85 }}>
          {done===HABITS.length?"🎉 All habits done! Legend!":HABITS.length-done+" remaining"}
        </p>
      </div>

      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:10 }}>
        {HABITS.map(h => {
          const isDone = habits[`${selKey}-${h.id}`];
          return (
            <div key={h.id} onClick={()=>toggle(h.id)} style={{ background:isDone?"#FF6B00":"#fff", border:"2px solid "+(isDone?"#FF6B00":"#FFE0C0"), borderRadius:18, padding:"18px 12px", cursor:"pointer", textAlign:"center", transition:"all .18s", transform:isDone?"scale(1.03)":"scale(1)", boxShadow:isDone?"0 4px 16px rgba(255,107,0,.22)":"0 2px 6px rgba(0,0,0,.04)" }}>
              <div style={{ fontSize:30, marginBottom:6 }}>{h.icon}</div>
              <div style={{ fontSize:12, fontWeight:700, color:isDone?"#fff":"#444", lineHeight:1.3 }}>{h.name}</div>
              <div style={{ marginTop:8, fontSize:20 }}>{isDone?"✅":"⭕"}</div>
            </div>
          );
        })}
      </div>

      {done===HABITS.length && (
        <div style={{ textAlign:"center", marginTop:18, padding:18, background:"#FFF8F0", borderRadius:16, border:"2px dashed #FFB347" }}>
          <div style={{ fontSize:38 }}>🏆</div>
          <p style={{ color:"#FF6B00", fontWeight:800, margin:"6px 0 0", fontSize:14 }}>Perfect! Keep it up Aryan!</p>
        </div>
      )}
    </div>
  );
}
