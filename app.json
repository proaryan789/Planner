  // ── task helpers
  const getTask = (sid, idx) => tasks[`${selKey}-${sid}-${idx}`] || null;
  const addTask = (sid, idx) => {
    const k = `${selKey}-${sid}-${idx}`;
    const val = (newInputs[k] || "").trim();
    if (!val) return;
    setTasks(p => ({ ...p, [k]: { text: val, pct: 0 } }));
